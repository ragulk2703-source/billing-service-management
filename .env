# Environment Configuration
# Copy this file to .env and update values as needed

# Application Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_PATH=data/database.sqlite

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Application Details
APP_NAME=Billing Service Management
APP_VERSION=1.0.0

# CORS Configuration
CORS_ORIGIN=*

# Email Configuration (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@servicecentre.com

# WhatsApp Configuration (Optional - for future use)
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_TEMPLATE_ID=your-template-id
WHATSAPP_BUSINESS_PHONE_ID=your-business-phone-id

# SMS Configuration (Optional - for future use)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=SCENTER

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf
UPLOAD_PATH=uploads

# Thermal Printer Configuration (Optional)
PRINTER_TYPE=usb
PRINTER_PORT=/dev/ttyUSB0
PRINTER_BAUDRATE=9600
PRINT_WIDTH=58

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_TIME=02:00
BACKUP_PATH=backups
BACKUP_RETENTION_DAYS=30

# Company Configuration
COMPANY_NAME=Your Service Center
COMPANY_PHONE=9999999999
COMPANY_EMAIL=admin@servicecentre.com
COMPANY_ADDRESS=123 Service Street
COMPANY_CITY=Bangalore
COMPANY_STATE=Karnataka
COMPANY_PINCODE=560001
COMPANY_GST_NUMBER=

# Invoice Configuration
INVOICE_PREFIX=INV
SERVICE_PREFIX=SER
INVOICE_NUMBERING=auto

# Default Settings
DEFAULT_TAX_RATE=18
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT=3600000

# Feature Flags
FEATURE_WHATSAPP=false
FEATURE_SMS=false
FEATURE_EMAIL=false
FEATURE_PRINTER=false
FEATURE_BACKUP_AUTO=true

# Debug Mode (Set to true only in development)
DEBUG=false
